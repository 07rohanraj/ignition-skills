              "tagType": "UdtInstance",
              "typeId": "Pump",
              "parameters": {"device": "Area1_PLC", "pumpId": "Pump1"}
            },
            {
              "name": "Pump2",
              "tagType": "UdtInstance",
              "typeId": "Pump",
              "parameters": {"device": "Area1_PLC", "pumpId": "Pump2"}
            },
            {
              "name": "Valve1",
              "tagType": "UdtInstance",
              "typeId": "Valve",
              "parameters": {"device": "Area1_PLC"}
            },
            {
