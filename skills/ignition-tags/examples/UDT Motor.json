          "opcItemPath": "ns=1;s=[{device}]/Motor/Amps",
          "engineeringUnit": "A",
          "historyEnabled": true,
          "historyProvider": "MySQL"
        },
        {
          "name": "HOA",
          "tagType": "AtomicTag",
